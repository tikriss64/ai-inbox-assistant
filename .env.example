# AI Inbox Assistant - Environment Variables
# Copy this file and configure your values
# For Cloudflare Workers, use: wrangler secret put SECRET_NAME

# Google OAuth (Gmail API)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# AI Provider
OPENAI_API_KEY=your_openai_api_key
OPENAI_BASE_URL=https://api.openai.com/v1

# App
APP_SECRET=your_random_secret_for_sessions
